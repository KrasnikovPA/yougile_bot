# Environment variables for local development
# Copy this file to .env and fill secrets. Do NOT commit .env with real tokens.

# Yougile API token (fill with your token)
# YOUGILE_TOKEN=your_yougile_token_here

# Board ID to use (example provided)
YOUGILE_BOARD=10ce6f83-6718-41f1-a788-8acbbe21de20

# Telegram bot token (fill with your Telegram bot token)
# TELEGRAM_TOKEN=your_telegram_token_here

# Optional retry policy overrides (ms/sec)
# YOUGILE_RETRY_COUNT=3
# YOUGILE_RETRY_WAIT_MS=500
# YOUGILE_MAX_RETRY_ELAPSED_SEC=10
YOUGILE_TOKEN=your_yougile_token_here
YOUGILE_BOARD=your_board_id_here
TELEGRAM_TOKEN=your_telegram_token_here
